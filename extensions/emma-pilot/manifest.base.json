{
  "manifest_version": 3,
  "name": "Emma Pilot",
  "version": "0.0.0",
  "description": "Emma AI browser copilot for Chrome and Edge.",
  "permissions": [
    "sidePanel",
    "storage",
    "tabs",
    "scripting",
    "identity",
    "activeTab"
  ],
  "optional_host_permissions": ["<all_urls>"],
  "host_permissions": [],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Emma Pilot",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
